<?xml version="1.0"?>
<launch>
  <let name="urdf_file" value="$(find-pkg-share bulls_bot)/urdf/bulls.urdf" />

  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher" output="screen">
    <param name="robot_description" value="$(file-content $(var urdf_file))" type="str" />
  </node>

  <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen" 
        args="-d $(find-pkg-share bulls_bot)/config/config.rviz" />
</launch>
